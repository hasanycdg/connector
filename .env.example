NODE_ENV=development
PORT=3000
TRUST_PROXY=false

# Firestore/Firebase Admin
FIREBASE_PROJECT_ID=connector-f0cf8
# For local emulator, set e.g. localhost:8080
FIRESTORE_EMULATOR_HOST=
# Optional namespace prefix for collections
FIRESTORE_COLLECTION_PREFIX=review_assistant

# Option 1 (recommended for production): service account via env vars
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Option 2: use Application Default Credentials (ADC)
FIREBASE_USE_APPLICATION_DEFAULT=false
d
GOOGLE_CLIENT_ID=test-google-client-id
GOOGLE_CLIENT_SECRET=test-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

OPENAI_API_KEY=test-openai-key
OPENAI_MODEL=gpt-4.1-mini

TWILIO_ACCOUNT_SID=AC00000000000000000000000000000000
TWILIO_AUTH_TOKEN=test-twilio-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+10000000000

# 32-byte test key (replace in real environments)
TOKEN_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

APP_BASE_URL=http://localhost:3000

# Polling at 10:00 and 18:00 every day (server timezone below)
POLL_CRON_SCHEDULE=0 10,18 * * *
POLL_TIMEZONE=Europe/Vienna

# Additional per-business jitter (seconds) to avoid hitting all businesses at once
POLL_STAGGER_SECONDS=7

# Optional: protect manual /jobs/poll-reviews trigger
INTERNAL_JOB_API_KEY=
